import java.io.IOException;
import java.nio.charset.StandardCharsets;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.util.ArrayList;
import java.util.Arrays;
import java.util.HashSet;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;
import java.util.Set;

public class NewCombo {

    // ----------------------------- knobs you may tweak -----------------------------

    static final String Input_CSV = "E:\\Anshul\\A\\A\\BRE\\BRE2.csv";
    static final String Out_Fname = "";   // "" -> derive from CSV filename

    /** INSERT template. Placeholders, in this exact order, are supplied by the code:
     *    %1$s FIELD_NAME   %2$s FIELD_VALUE   %3$s REQUEST_ACTION
     *    %4$s BACKEND_TYPE %5$s BACKEND_SUB_TYPE %6$s TRAN_CODE %7$s SERVICE_NAME
     *  Everything else is literal SQL. A literal percent sign must be written %%. */
    static final String INSERT_TEMPLATE =
        "INSERT INTO EISAPP.CACHE_DETAILS (FIELD_NAME, FIELD_VALUE, REQUEST_ACTION, PROCESSING_ACTION, RESPONSE_ACTION, SOURCE_ID, BACKEND_TYPE, BACKEND_SUB_TYPE, TRAN_CODE, SERVICE_NAME, CREATION_TIME) "
      + "VALUES ('%1$s','%2$s','%3$s','SOURCE ID CONFIGURATION','NULL','Multiple','%4$s','%5$s','%6$s','%7$s',TRUNC(SYSDATE));";

    /** %3$s REQUEST_ACTION. I do NOT know what this should be -- SET IT. (Empty -> Oracle NULL.) */
    static final String REQUEST_ACTION_VALUE = "";

    static final boolean hasHeader = false;

    static final Scope SYS_HTTP_TIMEOUT_SCOPE = Scope.DEST_TYPE;
    static final Set<String> ABSENT_SENTINELS = new HashSet<>(Arrays.asList("NA", "NULL"));

    // ------------------------------- field model -----------------------------------

    enum Scope { FULL, DEST_TYPE }
    enum Presence { ALWAYS, OPTIONAL }

    static final class FieldSpec {
        final String label, suffix;
        final Scope scope;
        final int valueColumn;
        final Presence presence;
        FieldSpec(String label, String suffix, Scope scope, int valueColumn, Presence presence) {
            this.label = label; this.suffix = suffix; this.scope = scope;
            this.valueColumn = valueColumn; this.presence = presence;
        }
    }

    /** One emitted cache row: the value PLUS the combination it came from (needed for the extra INSERT columns). */
    static final class Emit {
        final String value, destination, txnType, txnSubType, serviceName;
        Emit(String value, String destination, String txnType, String txnSubType, String serviceName) {
            this.value = value; this.destination = destination; this.txnType = txnType;
            this.txnSubType = txnSubType; this.serviceName = serviceName;
        }
    }

    static final List<FieldSpec> FIELDS = Arrays.asList(
        new FieldSpec("Content Check",    "_CONTENT_CHECK",   Scope.FULL,              9, Presence.ALWAYS),
        new FieldSpec("Source Auth",      "",                 Scope.FULL,             10, Presence.ALWAYS),
        new FieldSpec("Third Party URL",  "_THIRD_PARTY_URL", Scope.FULL,              3, Presence.ALWAYS),
        new FieldSpec("DMZ URL",          "_EIS_DMZ_URL",     Scope.FULL,              6, Presence.OPTIONAL),
        new FieldSpec("HTTP Timeout",     "_HTTPTimeout",     Scope.DEST_TYPE,         7, Presence.ALWAYS),
        new FieldSpec("Sys URL",          "_Sys_URL",         Scope.DEST_TYPE,         5, Presence.ALWAYS),
        new FieldSpec("Sys Service",      "_Sys_Service",     Scope.DEST_TYPE,         4, Presence.ALWAYS),
        new FieldSpec("Sys HTTP Timeout", "_SYS_HTTPTimeout", SYS_HTTP_TIMEOUT_SCOPE,  8, Presence.ALWAYS)
    );

    // ----------------------------------- main ---------------------------------------

    public static void main(String[] args) throws IOException {
        String inputPath = (args.length >= 1) ? args[0] : Input_CSV;
        if (inputPath == null || inputPath.trim().isEmpty()) {
            System.err.println("Set Input_CSV then run again.");
            System.exit(2);
        }

        Path in = Paths.get(inputPath);
        List<List<String>> rows = parseCsv(new String(Files.readAllBytes(in), StandardCharsets.UTF_8));

        LinkedHashMap<String, Emit> emitted = new LinkedHashMap<>();
        List<String> warnings = new ArrayList<>();
        int processed = 0, skippedRows = 0, skippedOptional = 0;

        for (int r = (hasHeader ? 1 : 0); r < rows.size(); r++) {
            List<String> row = rows.get(r);
            String d = get(row, 0), t = get(row, 1), s = get(row, 2);
            if (d.isEmpty() || t.isEmpty() || s.isEmpty()) {
                warnings.add("Row " + (r + 1) + " skipped: DESTINATION/TXN_TYPE/TXN_SUB_TYPE must all be non-empty.");
                skippedRows++;
                continue;
            }
            processed++;
            String serviceName = get(row, 4);   // CSV column 5 (SERVICE_NAME)
            for (FieldSpec f : FIELDS) {
                String raw = (f.valueColumn < 0) ? "" : get(row, f.valueColumn);
                if (f.presence == Presence.OPTIONAL && isAbsent(raw)) { skippedOptional++; continue; }

                String name = baseKey(d, t, s, f.scope) + f.suffix;
                if (emitted.containsKey(name)) {                       // already produced -> dedup
                    String prev = emitted.get(name).value;
                    if (!prev.equals(raw)) {
                        warnings.add("CONFLICT: '" + name + "' produced twice with different values: '"
                                + prev + "' vs '" + raw + "' (row " + (r + 1) + "). Kept the first; fix the CSV.");
                    }
                } else {
                    emitted.put(name, new Emit(raw, d, t, s, serviceName));
                }
            }
        }

        // ---- JSON ----
        StringBuilder json = new StringBuilder("[\n");
        int i = 0, total = emitted.size();
        for (Map.Entry<String, Emit> e : emitted.entrySet()) {
            json.append("  {\"FIELD_NAME\":\"").append(jsonEscape(e.getKey()))
                .append("\", \"FIELD_VALUE\":\"").append(jsonEscape(e.getValue().value)).append("\"}")
                .append(++i < total ? ",\n" : "\n");
        }
        json.append("]\n");

        // ---- SQL ----  (7 values passed, matching %1$s .. %7$s)
        StringBuilder sql = new StringBuilder();
        for (Map.Entry<String, Emit> e : emitted.entrySet()) {
            Emit em = e.getValue();
            sql.append(String.format(INSERT_TEMPLATE,
                    sqlEscape(e.getKey()),                 // %1$s FIELD_NAME
                    sqlEscape(em.value),                   // %2$s FIELD_VALUE
                    sqlEscape(REQUEST_ACTION_VALUE),       // %3$s REQUEST_ACTION
                    sqlEscape(em.destination),             // %4$s BACKEND_TYPE
                    sqlEscape(em.txnType),                 // %5$s BACKEND_SUB_TYPE
                    sqlEscape(em.txnSubType),              // %6$s TRAN_CODE
                    sqlEscape(em.serviceName)              // %7$s SERVICE_NAME
            )).append("\n");
        }

        String prefix = (args.length >= 2) ? args[1]
                      : (Out_Fname != null && !Out_Fname.trim().isEmpty() ? Out_Fname : stripExt(in.getFileName().toString()));
        Path jsonOut = Paths.get(prefix + ".json"), sqlOut = Paths.get(prefix + ".sql");
        Files.write(jsonOut, json.toString().getBytes(StandardCharsets.UTF_8));
        Files.write(sqlOut,  sql.toString().getBytes(StandardCharsets.UTF_8));

        System.out.println("Input  : " + in.toAbsolutePath());
        System.out.println("Combinations processed : " + processed + "  (skipped rows: " + skippedRows + ")");
        System.out.println("Fields emitted (deduped): " + emitted.size() + "  (optional fields skipped: " + skippedOptional + ")");
        System.out.println("JSON -> " + jsonOut.toAbsolutePath());
        System.out.println("SQL  -> " + sqlOut.toAbsolutePath());
        if (!warnings.isEmpty()) {
            System.out.println("\nWarnings (" + warnings.size() + "):");
            for (String w : warnings) System.out.println("  - " + w);
        }
    }

    // --------------------------------- helpers --------------------------------------

    static String baseKey(String d, String t, String s, Scope scope) {
        return scope == Scope.FULL ? d + "_" + t + "_" + s : d + "_" + t;
    }
    static boolean isAbsent(String v) { return v.isEmpty() || ABSENT_SENTINELS.contains(v.toUpperCase()); }
    static String get(List<String> row, int i) { return i < row.size() ? row.get(i).trim() : ""; }
    static String stripExt(String name) { int d = name.lastIndexOf('.'); return d > 0 ? name.substring(0, d) : name; }
    static String sqlEscape(String s) { return s.replace("'", "''"); }

    static String jsonEscape(String s) {
        StringBuilder b = new StringBuilder();
        for (int i = 0; i < s.length(); i++) {
            char c = s.charAt(i);
            switch (c) {
                case '"':  b.append("\\\""); break;
                case '\\': b.append("\\\\"); break;
                case '\n': b.append("\\n");  break;
                case '\r': b.append("\\r");  break;
                case '\t': b.append("\\t");  break;
                default:   if (c < 0x20) b.append(String.format("\\u%04x", (int) c)); else b.append(c);
            }
        }
        return b.toString();
    }

    static List<List<String>> parseCsv(String text) {
        List<List<String>> rows = new ArrayList<>();
        List<String> cur = new ArrayList<>();
        StringBuilder field = new StringBuilder();
        boolean inQuotes = false;
        int i = 0, n = text.length();
        while (i < n) {
            char c = text.charAt(i);
            if (inQuotes) {
                if (c == '"') {
                    if (i + 1 < n && text.charAt(i + 1) == '"') { field.append('"'); i += 2; continue; }
                    inQuotes = false; i++; continue;
                }
                field.append(c); i++; continue;
            }
            if (c == '"')  { inQuotes = true; i++; continue; }
            if (c == ',')  { cur.add(field.toString()); field.setLength(0); i++; continue; }
            if (c == '\r') { i++; continue; }
            if (c == '\n') { cur.add(field.toString()); field.setLength(0); rows.add(cur); cur = new ArrayList<>(); i++; continue; }
            field.append(c); i++;
        }
        cur.add(field.toString());
        rows.add(cur);
        rows.removeIf(row -> row.size() == 1 && row.get(0).trim().isEmpty());
        return rows;
    }
}
